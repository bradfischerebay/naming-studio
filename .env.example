# Chomsky (eBay Internal LLM Gateway)
# You must be connected to eBay VPN for this to work

# Main API Endpoint
CHOMSKY_ENDPOINT=https://chomskygw.vip.qa.ebay.com/api/v1/genai

# Model Configuration - Choose one:
# RECOMMENDED: GPT-5.2 (best balance of quality + rate limit)
CHOMSKY_MODEL=azure-chat-completions-gpt-5-2-2025-12-11-sandbox

# Alternative Models (uncomment to use):
# Claude Sonnet 4.6 (highest quality, but only 6 req/min)
# CHOMSKY_MODEL=gcp-chat-completions-anthropic-claude-sonnet-4.6-sandbox

# Claude Opus 4.6 (premium quality, only 6 req/min)
# CHOMSKY_MODEL=gcp-chat-completions-anthropic-claude-opus-4.6-sandbox

# GPT-5.2 Chat (faster, conversational, 180 req/min)
# CHOMSKY_MODEL=azure-chat-completions-gpt-5-2-chat-2025-12-11-sandbox

# Gemini 3.1 Pro (1M context, 300 req/min - fastest rate limit!)
# CHOMSKY_MODEL=gcp-chat-completions-chat-gemini-3.1-pro-preview-sandbox

# Legacy (outdated - don't use)
# CHOMSKY_MODEL=gcp-chat-completions-anthropic-claude-3.7-sonnet-sandbox

# Authentication Configuration (auto-configured, no action needed)
# Token endpoint: https://dcputilityexecutorsvc.vip.qa.ebay.com/dcp/executor/v1/apis/utilities/62f4a6871cb7d52b85a91429/run
# Tokens are cached for 6 hours and auto-refreshed

# Alternative Production Endpoint (if needed)
# CHOMSKY_ENDPOINT=https://chomskygw6cont.pp.vip.ebay.com/api/v1/genai
